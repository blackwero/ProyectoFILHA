@{
    ViewData["Title"] = "Bienvenido";
}

<div class="container d-flex justify-content-center align-items-center" style="height:80vh;">

    <div class="card shadow p-5 text-center" style="width:400px;">

        <h2 class="mb-4">Bienvenido</h2>
        <p class="text-muted">Selecciona una opción</p>

        <div class="d-grid gap-3 mt-4">

            <a asp-action="Entrar" class="btn btn-dark btn-lg">
                🔑 Entrar
            </a>

            <a asp-action="CrearCuenta" class="btn btn-outline-primary btn-lg">
                📝 Crear cuenta
            </a>

        </div>

    </div>

</div>