@model IEnumerable<ProyectoFILHA.Models.Entidades.Categoria>
@using ProyectoFILHA.Models.Enums

<h2>Categorías</h2>

<!-- FILTROS -->
<form method="get" class="row g-2 mb-4">

    <div class="col-md-4">
        <input type="text" name="buscar" value="@ViewBag.Buscar"
               class="form-control" placeholder="🔍 Buscar categoría..." />
    </div>

    <div class="col-md-3">
        <select name="estado" class="form-select">
            <option value="">-- Estado --</option>
            <option value="1" selected="@(ViewBag.Estado?.ToString() == "Activo")">Activo</option>
            <option value="0" selected="@(ViewBag.Estado?.ToString() == "Inactivo")">Inactivo</option>
        </select>
    </div>

    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-dark">Filtrar</button>
    </div>

    <div class="col-md-2 d-grid">
        <a asp-action="Index" class="btn btn-outline-secondary">
            Limpiar
        </a>
    </div>

</form>

<div class="d-flex justify-content-between mb-3">
    <h2>Categorías</h2>

    <a asp-action="Create" class="btn btn-success">
        + Nueva Categoría
    </a>
</div>

<!-- TABLA -->
<table class="table table-hover table-bordered align-middle">

    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Estado</th>
            <th style="width:150px;">Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>

                <td>
                    @if (item.Estado == ProyectoFILHA.Models.Enums.EstadoEnum.Activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn btn-info btn-sm">
                        👁
                    </a>

                    <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                        ✏️
                    </a>
                </td>
            </tr>
        }
    </tbody>

</table>

<nav>
    <ul class="pagination justify-content-center">

        <!-- Anterior -->
        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
            <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-buscar="@ViewBag.Buscar"
                   asp-route-estado="@ViewBag.Estado">
                Anterior
            </a>
        </li>

        <!-- Números -->
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-buscar="@ViewBag.Buscar"
                       asp-route-estado="@ViewBag.Estado">
                    @i
                </a>
            </li>
        }

        <!-- Siguiente -->
        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
            <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-buscar="@ViewBag.Buscar"
                   asp-route-estado="@ViewBag.Estado">
                Siguiente
            </a>
        </li>

    </ul>
</nav>

@section Scripts {
    <script>
        const input = document.querySelector('input[name="buscar"]');

        if (input) {
            input.addEventListener('keyup', function () {
                clearTimeout(this.delay);

                this.delay = setTimeout(() => {
                    this.form.submit();
                }, 400);
            });
        }
    </script>
}
